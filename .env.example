# ── Required ──────────────────────────────────────────────────────────
# Change these before running anything.

SECRET_KEY=changethis
ANTHROPIC_API_KEY=

# ── Auth defaults ─────────────────────────────────────────────────────
# First superuser created on startup; use these to log in.

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── Traefik / domain ─────────────────────────────────────────────────

DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local
PROJECT_NAME="Patient Encounter Portal PoC"
STACK_NAME=patient-encounter-portal-poc

# ── Backend ───────────────────────────────────────────────────────────

BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com,http://dashboard.localhost,https://dashboard.localhost"

# ── Email (mailcatcher in dev, real SMTP in prod) ─────────────────────

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ── Postgres ──────────────────────────────────────────────────────────

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ── Observability ─────────────────────────────────────────────────────

SENTRY_DSN=

# ── Docker images (override for custom registries) ───────────────────

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ── Celery broker (Redis) ────────────────────────────────────────────

CELERY_BROKER_URL=redis://redis:6379/0

# end